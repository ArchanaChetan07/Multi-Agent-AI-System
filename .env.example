# Environment template — copy to `.env` and fill in locally.
# Never commit real `.env` files.

# Force offline stubs (default when GROQ_API_KEY is unset)
DEMO_MODE=1

# Optional: enable optional Groq polish path in main.py --groq-polish
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Unused by the lightweight orchestrator; kept for reference if you wire a UI later
# OPENAI_API_KEY=
# PHI_API_KEY=
